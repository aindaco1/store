{
  "name": "store-worker",
  "version": "0.1.0",
  "description": "Cloudflare Worker for Store checkout, orders, inventory, shipping, tax, emails, and admin APIs",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "ruby ../scripts/sync-worker-config.rb && ruby ../scripts/generate-catalog-snapshot.rb && wrangler dev --env dev --ip 127.0.0.1 --port 8989",
    "deploy": "ruby ../scripts/sync-worker-config.rb && ruby ../scripts/generate-catalog-snapshot.rb && wrangler deploy --env=\"\"",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "wrangler": "^4.87.0"
  },
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "qrcode": "^1.5.4",
    "sales-tax": "^2.21.0"
  }
}
