{%- assign site_base = site.platform.site_url | default: site.url -%}
{%- assign sitemap_pages = site.pages | where_exp: "item", "item.layout == 'default'" | where_exp: "item", "item.sitemap != false" | where_exp: "item", "item.indexable != false" | where_exp: "item", "item.test_only != true" -%}
{%- assign sitemap_localized_products = site.pages | where_exp: "item", "item.store_product == true" | where_exp: "item", "item.sitemap != false" | where_exp: "item", "item.indexable != false" | where_exp: "item", "item.test_only != true" -%}
{%- assign sitemap_products = site.products | where_exp: "item", "item.sitemap != false" | where_exp: "item", "item.indexable != false" | where_exp: "item", "item.test_only != true" -%}
{%- for item in sitemap_pages -%}
  {%- if include.format == 'text' -%}
    {%- include seo-sitemap-url.txt item=item site_base=site_base -%}
  {%- else -%}
    {%- include seo-sitemap-url.xml item=item -%}
  {%- endif -%}
{%- endfor -%}
{%- for item in sitemap_localized_products -%}
  {%- assign product_status = item.status | default: "active" -%}
  {%- assign product_public = true -%}
  {%- if item.public == false -%}
    {%- assign product_public = false -%}
  {%- endif -%}
  {%- if product_public and product_status == "active" or product_public and product_status == "sold_out" -%}
    {%- if include.format == 'text' -%}
      {%- include seo-sitemap-url.txt item=item site_base=site_base -%}
    {%- else -%}
      {%- include seo-sitemap-url.xml item=item -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
{%- for item in sitemap_products -%}
  {%- assign product_status = item.status | default: "active" -%}
  {%- assign product_public = true -%}
  {%- if item.public == false -%}
    {%- assign product_public = false -%}
  {%- endif -%}
  {%- if product_public and product_status == "active" or product_public and product_status == "sold_out" -%}
    {%- if include.format == 'text' -%}
      {%- include seo-sitemap-url.txt item=item site_base=site_base -%}
    {%- else -%}
      {%- include seo-sitemap-url.xml item=item -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
