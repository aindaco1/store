{
  "schemaVersion": 1,
  "owner": "Store operations",
  "recoveryObjectives": {
    "gitConfigBuild": { "rpo": "each release", "rtoHours": 1 },
    "ordersAndAdminState": { "rpoHours": 4, "rtoHours": 4 },
    "r2Objects": { "rpo": "after create or replace and before delete", "rtoHours": 4 },
    "preChange": { "rpo": "before bulk import, restore, inventory reset, or provider migration", "rtoHours": 1 }
  },
  "retention": {
    "daily": 7,
    "weekly": 5,
    "monthly": 12,
    "releaseSnapshots": true,
    "offAccountCopiesMinimum": 1,
    "encryptionRequiredForSensitiveValues": true
  },
  "families": [
    { "id": "orders", "binding": "STORE_STATE", "type": "kv", "prefix": "orders:", "sourceOfTruth": "Store Worker order records", "sensitivity": "restricted-pii-payment-metadata", "backupFrequency": "4h-active-sales", "retention": "business-record-policy", "restorePhase": 3, "validation": "valid JSON; orderToken matches key; status and orderDraft present", "owner": "Store operations", "classification": "authoritative", "backupValues": true, "restoreDefault": "restore" },
    { "id": "inventory-overrides", "binding": "STORE_STATE", "type": "kv", "prefix": "store-inventory-overrides:v1", "sourceOfTruth": "admin inventory overrides", "sensitivity": "internal", "backupFrequency": "4h-active-sales-and-pre-change", "retention": "snapshot-retention", "restorePhase": 4, "validation": "versioned JSON with non-negative inventory values", "owner": "Store operations", "classification": "authoritative", "backupValues": true, "restoreDefault": "restore" },
    { "id": "coupons", "binding": "STORE_STATE", "type": "kv", "prefix": "store-coupons:v1", "sourceOfTruth": "admin coupon definitions", "sensitivity": "internal-commercial", "backupFrequency": "4h-active-sales", "retention": "snapshot-retention", "restorePhase": 4, "validation": "versioned JSON coupon list with unique normalized codes", "owner": "Store operations", "classification": "authoritative", "backupValues": true, "restoreDefault": "restore" },
    { "id": "addon-inventory-overrides", "binding": "STORE_STATE", "type": "kv", "prefix": "add-on-inventory-overrides", "sourceOfTruth": "admin add-on inventory overrides", "sensitivity": "internal", "backupFrequency": "4h-active-sales-and-pre-change", "retention": "snapshot-retention", "restorePhase": 4, "validation": "versioned JSON with non-negative inventory values", "owner": "Store operations", "classification": "authoritative", "backupValues": true, "restoreDefault": "restore" },
    { "id": "admin-users", "binding": "STORE_STATE", "type": "kv", "prefix": "admin-users:v1", "sourceOfTruth": "runtime admin users and scopes", "sensitivity": "restricted-admin-pii", "backupFrequency": "4h-and-after-change", "retention": "snapshot-retention", "restorePhase": 2, "validation": "versioned JSON; valid unique emails; known roles and scopes", "owner": "Platform security", "classification": "authoritative", "backupValues": true, "restoreDefault": "restore-with-break-glass-review" },
    { "id": "legacy-admin-users", "binding": "STORE_STATE", "type": "kv", "prefix": "admin-user:", "sourceOfTruth": "legacy per-user admin records", "sensitivity": "restricted-admin-pii", "backupFrequency": "4h-and-after-change", "retention": "snapshot-retention", "restorePhase": 2, "validation": "valid JSON; known role and scopes", "owner": "Platform security", "classification": "authoritative", "backupValues": true, "restoreDefault": "restore-with-break-glass-review" },
    { "id": "marketing-referrals", "binding": "STORE_STATE", "type": "kv", "prefix": "admin-store-marketing-referrals:v1", "sourceOfTruth": "saved referral definitions", "sensitivity": "internal-commercial", "backupFrequency": "daily-and-after-change", "retention": "snapshot-retention", "restorePhase": 4, "validation": "JSON array with unique URL-safe codes", "owner": "Store marketing", "classification": "authoritative", "backupValues": true, "restoreDefault": "restore" },
    { "id": "abandoned-cart-suppressions", "binding": "STORE_STATE", "type": "kv", "prefix": "abandoned-cart-suppressed:", "sourceOfTruth": "customer reminder suppression preferences", "sensitivity": "restricted-hashed-identity", "backupFrequency": "4h", "retention": "privacy-policy", "restorePhase": 4, "validation": "valid JSON with email hash and suppression timestamp", "owner": "Store operations", "classification": "authoritative", "backupValues": true, "restoreDefault": "restore-before-reminders" },

    { "id": "stripe-events", "binding": "STORE_STATE", "type": "kv", "prefix": "stripe-event:", "sourceOfTruth": "Stripe webhook idempotency marker", "sensitivity": "internal-provider-id", "backupFrequency": "4h-active-sales", "retention": "provider-replay-window", "restorePhase": 5, "validation": "processed marker keyed by Stripe event ID", "owner": "Payments operations", "classification": "idempotency-control", "backupValues": true, "restoreDefault": "restore-before-webhooks" },
    { "id": "customer-email-sent", "binding": "STORE_STATE", "type": "kv", "prefix": "store-order-email-sent:", "sourceOfTruth": "customer email idempotency marker", "sensitivity": "internal-order-token", "backupFrequency": "4h-active-sales", "retention": "email-replay-window", "restorePhase": 5, "validation": "sent marker keyed by order token", "owner": "Store operations", "classification": "idempotency-control", "backupValues": true, "restoreDefault": "restore-before-email-jobs" },
    { "id": "admin-email-sent", "binding": "STORE_STATE", "type": "kv", "prefix": "store-order-admin-email-sent:", "sourceOfTruth": "admin notification idempotency marker", "sensitivity": "restricted-hashed-admin-identity", "backupFrequency": "4h-active-sales", "retention": "email-replay-window", "restorePhase": 5, "validation": "sent marker keyed by order token and admin email hash", "owner": "Store operations", "classification": "idempotency-control", "backupValues": true, "restoreDefault": "restore-before-email-jobs" },
    { "id": "abandoned-cart-sent", "binding": "STORE_STATE", "type": "kv", "prefix": "abandoned-cart-sent:", "sourceOfTruth": "abandoned reminder idempotency marker", "sensitivity": "restricted-hashed-identity", "backupFrequency": "4h", "retention": "reminder-replay-window", "restorePhase": 5, "validation": "sent timestamp keyed by email and cart hashes", "owner": "Store operations", "classification": "idempotency-control", "backupValues": true, "restoreDefault": "restore-before-reminders" },
    { "id": "event-reminder-sent", "binding": "STORE_STATE", "type": "kv", "prefix": "store-event-reminder-sent:", "sourceOfTruth": "event reminder idempotency marker", "sensitivity": "internal-order-token", "backupFrequency": "4h", "retention": "reminder-replay-window", "restorePhase": 5, "validation": "sent timestamp keyed by reminder identity", "owner": "Store operations", "classification": "idempotency-control", "backupValues": true, "restoreDefault": "restore-before-reminders" },

    { "id": "admin-order-index", "binding": "STORE_STATE", "type": "kv", "prefix": "admin-store-orders:index:v2", "sourceOfTruth": "orders: records", "sensitivity": "restricted-derived-pii", "backupFrequency": "metadata-only", "retention": "ttl", "restorePhase": 7, "validation": "shared v2 read-model validator", "owner": "Store engineering", "classification": "derived-rebuildable", "backupValues": false, "restoreDefault": "rebuild" },
    { "id": "inventory-projection", "binding": "STORE_STATE", "type": "kv", "prefix": "store-inventory:v1:", "sourceOfTruth": "orders plus inventory coordinator state", "sensitivity": "internal", "backupFrequency": "metadata-only", "retention": "ttl", "restorePhase": 7, "validation": "non-negative SKU counts", "owner": "Store engineering", "classification": "derived-rebuildable", "backupValues": false, "restoreDefault": "rebuild" },
    { "id": "addon-inventory-projection", "binding": "STORE_STATE", "type": "kv", "prefix": "add-on-inventory-sold:v1", "sourceOfTruth": "orders: records", "sensitivity": "internal", "backupFrequency": "metadata-only", "retention": "ttl", "restorePhase": 7, "validation": "non-negative SKU counts", "owner": "Store engineering", "classification": "derived-rebuildable", "backupValues": false, "restoreDefault": "rebuild" },
    { "id": "order-email-index", "binding": "STORE_STATE", "type": "kv", "prefix": "store-order-email:", "sourceOfTruth": "orders: records", "sensitivity": "restricted-hashed-identity", "backupFrequency": "metadata-only", "retention": "order-lookup-window", "restorePhase": 7, "validation": "versioned index; order tokens exist", "owner": "Store engineering", "classification": "derived-rebuildable", "backupValues": false, "restoreDefault": "rebuild" },
    { "id": "abandoned-cart-queue", "binding": "STORE_STATE", "type": "kv", "prefix": "abandoned-cart-queue:v1", "sourceOfTruth": "abandoned-cart: records", "sensitivity": "internal", "backupFrequency": "metadata-only", "retention": "ttl", "restorePhase": 7, "validation": "versioned queue summary", "owner": "Store engineering", "classification": "derived-rebuildable", "backupValues": false, "restoreDefault": "rebuild" },
    { "id": "abandoned-cart-health", "binding": "STORE_STATE", "type": "kv", "prefix": "abandoned-cart-health:v1", "sourceOfTruth": "reminder processing", "sensitivity": "internal", "backupFrequency": "metadata-only", "retention": "ttl", "restorePhase": 7, "validation": "versioned health summary", "owner": "Store engineering", "classification": "derived-rebuildable", "backupValues": false, "restoreDefault": "rebuild" },
    { "id": "event-reminder-queue", "binding": "STORE_STATE", "type": "kv", "prefix": "store-event-reminder-queue:v1", "sourceOfTruth": "store-event-reminder: records", "sensitivity": "internal", "backupFrequency": "metadata-only", "retention": "ttl", "restorePhase": 7, "validation": "versioned queue summary", "owner": "Store engineering", "classification": "derived-rebuildable", "backupValues": false, "restoreDefault": "rebuild" },
    { "id": "event-address-lookup", "binding": "STORE_STATE", "type": "kv", "prefix": "store-event-address-lookup:", "sourceOfTruth": "address lookup provider", "sensitivity": "public-address", "backupFrequency": "none", "retention": "ttl", "restorePhase": 7, "validation": "bounded provider response cache", "owner": "Store engineering", "classification": "derived-rebuildable", "backupValues": false, "restoreDefault": "rebuild" },

    { "id": "admin-audit", "binding": "STORE_STATE", "type": "kv", "prefix": "admin-audit:", "sourceOfTruth": "admin mutation audit events", "sensitivity": "restricted-admin-activity", "backupFrequency": "daily", "retention": "400-days", "restorePhase": 6, "validation": "valid event JSON with action and createdAt", "owner": "Platform security", "classification": "incident-evidence", "backupValues": true, "restoreDefault": "restore-if-incident-required" },
    { "id": "observability", "binding": "STORE_STATE", "type": "kv", "prefix": "observability:", "sourceOfTruth": "sampled Worker telemetry", "sensitivity": "internal-sanitized", "backupFrequency": "incident-only", "retention": "14-days", "restorePhase": 8, "validation": "bounded summary or recent-event JSON", "owner": "Store engineering", "classification": "incident-evidence", "backupValues": false, "restoreDefault": "do-not-restore" },
    { "id": "workers-cache-purge-failure", "binding": "STORE_STATE", "type": "kv", "prefix": "workers-cache-purge-failure:recent", "sourceOfTruth": "failure-only cache purge diagnostics", "sensitivity": "internal-sanitized", "backupFrequency": "incident-only", "retention": "7-days", "restorePhase": 8, "validation": "bounded domains, status, error, and timestamp only", "owner": "Store engineering", "classification": "incident-evidence", "backupValues": false, "restoreDefault": "do-not-restore" },

    { "id": "admin-sessions", "binding": "STORE_STATE", "type": "kv", "prefix": "admin-session:", "sourceOfTruth": "short-lived authentication state", "sensitivity": "secret-session", "backupFrequency": "none", "retention": "ttl", "restorePhase": 9, "validation": "never restore", "owner": "Platform security", "classification": "ephemeral-quarantined", "backupValues": false, "restoreDefault": "quarantine" },
    { "id": "admin-login-nonces", "binding": "STORE_STATE", "type": "kv", "prefix": "admin-login:", "sourceOfTruth": "short-lived authentication state", "sensitivity": "secret-login-token", "backupFrequency": "none", "retention": "ttl", "restorePhase": 9, "validation": "never restore", "owner": "Platform security", "classification": "ephemeral-quarantined", "backupValues": false, "restoreDefault": "quarantine" },
    { "id": "rate-limits", "binding": "RATELIMIT", "type": "kv", "prefix": "rl:", "sourceOfTruth": "short-lived request counters", "sensitivity": "internal-network-metadata", "backupFrequency": "none", "retention": "ttl", "restorePhase": 9, "validation": "never restore", "owner": "Platform security", "classification": "ephemeral-quarantined", "backupValues": false, "restoreDefault": "quarantine" },
    { "id": "order-lookup-tokens", "binding": "STORE_STATE", "type": "kv", "prefix": "store-order-lookup:", "sourceOfTruth": "one-time lookup capability", "sensitivity": "secret-capability", "backupFrequency": "none", "retention": "ttl", "restorePhase": 9, "validation": "never restore", "owner": "Platform security", "classification": "ephemeral-quarantined", "backupValues": false, "restoreDefault": "quarantine" },
    { "id": "abandoned-cart-resume", "binding": "STORE_STATE", "type": "kv", "prefix": "abandoned-cart-resume:", "sourceOfTruth": "short-lived resume capability", "sensitivity": "restricted-cart-pii", "backupFrequency": "none", "retention": "ttl", "restorePhase": 9, "validation": "never restore", "owner": "Store operations", "classification": "ephemeral-quarantined", "backupValues": false, "restoreDefault": "quarantine" },
    { "id": "abandoned-cart-pending", "binding": "STORE_STATE", "type": "kv", "prefix": "abandoned-cart:", "sourceOfTruth": "short-lived reminder candidate", "sensitivity": "restricted-cart-pii", "backupFrequency": "none", "retention": "ttl", "restorePhase": 9, "validation": "do not restore to avoid duplicate or stale reminders", "owner": "Store operations", "classification": "ephemeral-quarantined", "backupValues": false, "restoreDefault": "quarantine" },
    { "id": "event-reminder-pending", "binding": "STORE_STATE", "type": "kv", "prefix": "store-event-reminder:", "sourceOfTruth": "short-lived reminder candidate", "sensitivity": "restricted-order-pii", "backupFrequency": "none", "retention": "ttl", "restorePhase": 9, "validation": "do not restore to avoid duplicate or stale reminders", "owner": "Store operations", "classification": "ephemeral-quarantined", "backupValues": false, "restoreDefault": "quarantine" },
    { "id": "marketing-draft", "binding": "STORE_STATE", "type": "kv", "prefix": "admin-store-marketing-draft:builder", "sourceOfTruth": "short-lived admin draft", "sensitivity": "internal", "backupFrequency": "none", "retention": "ttl", "restorePhase": 9, "validation": "never restore", "owner": "Store marketing", "classification": "ephemeral-quarantined", "backupValues": false, "restoreDefault": "quarantine" },
    { "id": "cron-markers", "binding": "STORE_STATE", "type": "kv", "prefix": "cron:", "sourceOfTruth": "short-lived scheduler state", "sensitivity": "internal", "backupFrequency": "none", "retention": "ttl", "restorePhase": 9, "validation": "never restore", "owner": "Store engineering", "classification": "ephemeral-quarantined", "backupValues": false, "restoreDefault": "quarantine" },

    { "id": "store-downloads", "binding": "STORE_DOWNLOADS", "type": "r2", "prefix": "*", "sourceOfTruth": "private digital fulfillment objects", "sensitivity": "restricted-copyrighted-private-object", "backupFrequency": "after-create-replace-and-before-delete", "retention": "snapshot-retention", "restorePhase": 5, "validation": "object size and SHA-256 match manifest; referenced catalog keys resolve", "owner": "Store operations", "classification": "authoritative", "backupValues": true, "restoreDefault": "restore" },
    { "id": "inventory-coordinator", "binding": "STORE_INVENTORY_COORDINATOR", "type": "durable-object", "prefix": "*", "sourceOfTruth": "live inventory reservation coordinator", "sensitivity": "internal-order-state", "backupFrequency": "provider-snapshot-not-supported", "retention": "provider-managed", "restorePhase": 6, "validation": "reconcile reservations against restored orders and inventory", "owner": "Store engineering", "classification": "derived-rebuildable", "backupValues": false, "restoreDefault": "reconcile-not-import" }
  ]
}
